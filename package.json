{
  "name": "music-chord-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.21",
  "engines": {
    "node": ">=20.0.0",
    "yarn": ">=1.22.0"
  },
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "lint:check": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:mobile": "playwright test --project=chromium-mobile",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "admin:test:e2e": "playwright test -c admin-dashboard/playwright.config.ts",
    "admin:test:e2e:mobile": "playwright test -c admin-dashboard/playwright.config.ts --project=chromium-mobile",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:recover:vercel-migration": "bash ./scripts/recover-vercel-prisma-migration.sh",
    "db:seed": "node prisma/seed-admin.js",
    "db:studio": "prisma studio",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:stories": "vitest --project=storybook --run",
    "test:stories:watch": "vitest --project=storybook",
    "admin:dev": "yarn --cwd admin-dashboard dev",
    "admin:build": "yarn --cwd admin-dashboard build",
    "admin:start": "yarn --cwd admin-dashboard start",
    "admin:lint": "yarn --cwd admin-dashboard lint",
    "admin:db:generate": "yarn --cwd admin-dashboard db:generate",
    "admin:seed": "node prisma/seed-admin.js",
    "wiki:publish": "bash ./scripts/publish-wiki.sh"
  },
  "dependencies": {
    "@carlwelchdesign/webauthn-core": "file:packages/webauthn-core",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@prisma/client": "^5.10.0",
    "@sentry/nextjs": "^10.46.0",
    "@sentry/replay": "^7.116.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tonejs/midi": "^2.0.28",
    "i18next": "^26.0.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "next": "^15.5.14",
    "openai": "^5.0.0",
    "piano-chart": "^1.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^17.0.1",
    "stripe": "^21.0.1",
    "stylis": "^4.3.6",
    "stylis-plugin-rtl": "^2.1.1",
    "svguitar": "^2.5.1",
    "tone": "^15.1.22"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.0",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/nextjs-vite": "^10.3.3",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitest/browser-playwright": "^4.1.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-storybook": "^10.3.3",
    "husky": "^9.1.7",
    "jest": "^30",
    "jest-environment-jsdom": "^30",
    "lint-staged": "^16.4.0",
    "msw": "^2.12.14",
    "msw-storybook-addon": "^2.0.6",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prisma": "^5.10.0",
    "storybook": "^10.3.3",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  },
  "resolutions": {
    "**/brace-expansion": ">=5.0.5",
    "**/flatted": "3.4.2",
    "**/cosmiconfig/yaml": "1.10.3",
    "**/handlebars": "4.7.9"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "eslint"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
