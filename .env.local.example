# GitHub Packages — required to install @carlwelchdesign/webauthn-core (private registry)
# Create a GitHub PAT with read:packages scope at https://github.com/settings/tokens
# Must also be set in Vercel: Settings → Environment Variables → NPM_TOKEN
NPM_TOKEN=ghp_replace_me

# OpenAI — required for chord suggestion generation
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Database — required for saving progressions and user accounts
# Local dev (Docker): same value for both DATABASE_URL and DIRECT_URL
# Vercel + Prisma Accelerate: DATABASE_URL = prisma://... accelerate URL; DIRECT_URL = direct postgres:// URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/progression_lab
# DIRECT_URL is used by `prisma migrate deploy` (must be a direct postgres:// connection, not an Accelerate URL)
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/progression_lab

# Billing / Stripe — required for subscription checkout, portal, and webhook sync
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Optional: comma-separated fallback secrets for webhook secret rotation
STRIPE_WEBHOOK_SECRETS=whsec_old,whsec_new
STRIPE_COMPOSER_MONTHLY_PRICE_ID=price_replace_me
STRIPE_COMPOSER_YEARLY_PRICE_ID=price_replace_me
STRIPE_STUDIO_MONTHLY_PRICE_ID=price_replace_me
STRIPE_STUDIO_YEARLY_PRICE_ID=price_replace_me

# Auth — REQUIRED in production. Generate with: openssl rand -base64 32
# Must be set as an environment variable on Vercel (Settings → Environment Variables)
AUTH_SECRET=replace_with_output_of_openssl_rand_base64_32

# WebAuthn / Passkeys — used for optional user enrollment and required admin MFA
# Use localhost in local development. Production origins must be exact HTTPS origins.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=ProgressionLab
WEBAUTHN_ORIGIN=http://localhost:3000
ADMIN_WEBAUTHN_ORIGIN=http://localhost:3010

# Sentry — required for error monitoring in production. Generate a DSN and auth token in Sentry, then set these values as environment variables on Vercel (Settings → Environment Variables)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_OTLP_TRACES_URL=""
SENTRY_PROJECT="sentry-your-project-name"
SENTRY_PUBLIC_KEY=""
SENTRY_VERCEL_LOG_DRAIN_URL=""