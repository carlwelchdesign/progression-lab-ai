# Shared database used by main app and admin dashboard
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/progression_lab

# Admin session signing secret (recommended dedicated secret)
ADMIN_AUTH_SECRET=replace_with_output_of_openssl_rand_base64_32

# Optional fallback if ADMIN_AUTH_SECRET is omitted in local/dev
AUTH_SECRET=replace_with_output_of_openssl_rand_base64_32
