{
  "name": "progression-lab-admin",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.21",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3010",
    "build": "prisma generate --schema ./prisma/schema.prisma && next build",
    "build:deploy": "npx prisma generate && npm run build",
    "start": "next start -H 0.0.0.0 -p 3010",
    "lint": "next lint",
    "db:generate": "prisma generate --schema ./prisma/schema.prisma",
    "test:e2e": "playwright test -c playwright.config.ts",
    "test:e2e:mobile": "playwright test -c playwright.config.ts --project=chromium-mobile"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@prisma/client": "^5.22.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "next": "^15.5.14",
    "openai": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.2.0",
    "prisma": "^5.22.0",
    "typescript": "^5.8.2"
  },
  "resolutions": {
    "**/brace-expansion": ">=5.0.5",
    "**/anymatch/picomatch": "2.3.2",
    "**/jest-util/picomatch": "2.3.2",
    "**/micromatch/picomatch": "2.3.2",
    "**/lint-staged/picomatch": "4.0.4",
    "**/tinyglobby/picomatch": "4.0.4",
    "**/unplugin/picomatch": "4.0.4",
    "**/vite/picomatch": "4.0.4",
    "**/vitest/picomatch": "4.0.4"
  }
}
