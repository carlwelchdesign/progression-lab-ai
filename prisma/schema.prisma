// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  AUDITOR
  USER
}

enum SubscriptionPlan {
  SESSION
  COMPOSER
  STUDIO
  COMP
  INVITE
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

enum UsageEventType {
  AI_GENERATION
  MIDI_EXPORT
  PDF_EXPORT
}

enum PromoCodeType {
  DISCOUNT
  INVITE
}

enum PromoRedemptionStatus {
  REDEEMED
  REJECTED
}

enum MfaPolicy {
  NONE
  OPTIONAL
  REQUIRED_ADMIN
}

enum MfaEnrollmentState {
  NONE
  PENDING
  ACTIVE
}

enum WebAuthnFlowType {
  CUSTOMER_REGISTRATION
  ADMIN_AUTHENTICATION
  ADMIN_BOOTSTRAP_REGISTRATION
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String?
  role         UserRole      @default(USER)
  stripeCustomerId String?   @unique
  planOverride SubscriptionPlan?
  planOverrideExpiresAt DateTime?
  mfaPolicy    MfaPolicy      @default(NONE)
  mfaEnrollmentState MfaEnrollmentState @default(NONE)
  mfaEnabledAt DateTime?
  lastMfaVerifiedAt DateTime?
  mfaBypassUntil DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  progressions Progression[]
  arrangements Arrangement[]
  subscription Subscription?
  usageEvents  UsageEvent[]
  adminAuditLogs AdminAuditLog[]
  promptVersions PromptVersion[]
  webauthnCredentials WebAuthnCredential[]
  webauthnChallenges WebAuthnChallenge[]
  createdPromoCodes PromoCode[] @relation("PromoCodeCreatedBy")
  promoCodeRedemptions PromoCodeRedemption[]
}

model WebAuthnCredential {
  id           String   @id @default(cuid())
  userId       String
  credentialId String   @unique
  publicKey    String   @db.Text
  counter      BigInt   @default(0)
  deviceType   String?
  backedUp     Boolean?
  transports   String[] @default([])
  label        String?
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime?
  revokedAt    DateTime?

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
}

model WebAuthnChallenge {
  id         String           @id @default(cuid())
  userId     String
  flowType   WebAuthnFlowType
  challenge  String
  expiresAt  DateTime
  consumedAt DateTime?
  metadata   Json?
  createdAt  DateTime         @default(now())

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, flowType])
  @@index([expiresAt])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 SubscriptionPlan
  billingInterval      BillingInterval?
  status               SubscriptionStatus @default(ACTIVE)
  appliedPromoCode     String?
  stripePromotionCodeId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([plan, status])
  @@index([appliedPromoCode])
}

model PromoCode {
  id                     String             @id @default(cuid())
  code                   String             @unique
  type                   PromoCodeType
  isActive               Boolean            @default(true)
  startsAt               DateTime?
  expiresAt              DateTime?
  maxRedemptions         Int?
  currentRedemptions     Int                @default(0)
  isSingleUse            Boolean            @default(false)
  allowedPlans           SubscriptionPlan[]
  allowedBillingIntervals BillingInterval[]
  grantedPlan            SubscriptionPlan?
  inviteDurationDays     Int?
  maxSavedProgressions   Int?
  maxSavedArrangements   Int?
  aiGenerationsPerMonth  Int?
  stripePromotionCodeId  String?
  metadata               Json?
  createdByUserId        String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  createdByUser          User?              @relation("PromoCodeCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  redemptions            PromoCodeRedemption[]

  @@index([type, isActive, expiresAt])
  @@index([createdAt])
}

model PromoCodeRedemption {
  id                   String               @id @default(cuid())
  promoCodeId          String
  userId               String
  status               PromoRedemptionStatus @default(REDEEMED)
  failureReason        String?
  checkoutSessionId    String?
  stripeSubscriptionId String?
  metadata             Json?
  redeemedAt           DateTime             @default(now())

  promoCode            PromoCode            @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, userId])
  @@index([userId, redeemedAt])
  @@index([promoCodeId, redeemedAt])
}

model UsageEvent {
  id        String         @id @default(cuid())
  userId    String
  eventType UsageEventType
  quantity  Int            @default(1)
  metadata  Json?
  createdAt DateTime       @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, eventType, createdAt])
}

model SubscriptionTierConfig {
  plan                   SubscriptionPlan @id
  gptModel               String
  aiGenerationsPerMonth  Int?
  maxSavedProgressions   Int?
  maxSavedArrangements   Int?
  maxPublicShares        Int?
  canExportMidi          Boolean          @default(false)
  canExportPdf           Boolean          @default(false)
  canSharePublicly       Boolean          @default(true)
  canUseAdvancedVoicingControls Boolean?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
}

model SubscriptionPlanVersion {
  id                      String   @id @default(cuid())
  planId                  String   // e.g. 'SESSION', 'COMPOSER', 'STUDIO'
  displayName             String   // User-facing name
  description             String
  monthlyPrice            Decimal  @db.Decimal(10, 2)
  yearlyPrice             Decimal  @db.Decimal(10, 2)
  monthlyStripePriceId    String?
  yearlyStripePriceId     String?
  gptModel                String   // e.g. 'gpt-3.5-turbo', 'gpt-4o'
  aiGenerationsPerMonth   Int?     // null = unlimited
  maxSavedProgressions    Int?     // null = unlimited
  maxSavedArrangements    Int?     // null = unlimited
  maxPublicShares         Int?     // null = unlimited
  canExportMidi           Boolean  @default(false)
  canExportPdf            Boolean  @default(false)
  canSharePublicly        Boolean  @default(true)
  canUsePremiumAiModel    Boolean  @default(false)
  versionNumber           Int      // Incremented on each new version
  isDraft                 Boolean  @default(false)
  isActive                Boolean  @default(false)
  publishedAt             DateTime?
  editorEmail             String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([planId, versionNumber])
  @@index([isActive])
  @@index([isDraft])
  @@index([planId, isActive])
  @@index([planId, createdAt])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorEmail  String
  actorRole   UserRole
  action      String
  targetType  String
  targetId    String
  metadata    Json?
  createdAt   DateTime @default(now())

  actorUser User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([actorUserId, createdAt])
}

model PromptVersion {
  id              String   @id @default(cuid())
  promptKey       String
  versionNumber   Int
  contentTemplate String
  notes           String?
  isDraft         Boolean  @default(false)
  isActive        Boolean  @default(false)
  createdByUserId String?
  createdByEmail  String?
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdByUser User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([promptKey, versionNumber])
  @@index([promptKey, isActive])
  @@index([promptKey, isDraft])
  @@index([promptKey, createdAt])
}

model Progression {
  id         String   @id @default(cuid())
  shareId    String   @unique @default(cuid())
  userId     String
  title      String
  chords     Json
  pianoVoicings Json?
  generatorSnapshot Json?
  feel       String?
  scale      String?
  genre      String?
  notes      String?
  tags       String[]
  isPublic   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([shareId])
}

model Arrangement {
  id               String   @id @default(cuid())
  shareId          String   @unique @default(cuid())
  userId           String
  title            String
  timeline         Json
  playbackSnapshot Json
  sourceChords     Json?
  notes            String?
  tags             String[] @default([])
  isPublic         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([shareId])
}
