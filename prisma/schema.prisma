// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  AUDITOR
  USER
}

enum SubscriptionPlan {
  SESSION
  COMPOSER
  STUDIO
  COMP
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

enum UsageEventType {
  AI_GENERATION
  MIDI_EXPORT
  PDF_EXPORT
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String?
  role         UserRole      @default(USER)
  stripeCustomerId String?   @unique
  planOverride SubscriptionPlan?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  progressions Progression[]
  arrangements Arrangement[]
  subscription Subscription?
  usageEvents  UsageEvent[]
  adminAuditLogs AdminAuditLog[]
  promptVersions PromptVersion[]
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 SubscriptionPlan
  billingInterval      BillingInterval?
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([plan, status])
}

model UsageEvent {
  id        String         @id @default(cuid())
  userId    String
  eventType UsageEventType
  quantity  Int            @default(1)
  metadata  Json?
  createdAt DateTime       @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, eventType, createdAt])
}

model SubscriptionTierConfig {
  plan                   SubscriptionPlan @id
  gptModel               String
  aiGenerationsPerMonth  Int?
  maxSavedProgressions   Int?
  maxSavedArrangements   Int?
  maxPublicShares        Int?
  canExportMidi          Boolean          @default(false)
  canExportPdf           Boolean          @default(false)
  canSharePublicly       Boolean          @default(true)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
}

model SubscriptionPlanVersion {
  id                      String   @id @default(cuid())
  planId                  String   // e.g. 'SESSION', 'COMPOSER', 'STUDIO'
  displayName             String   // User-facing name
  description             String
  monthlyPrice            Decimal  @db.Decimal(10, 2)
  yearlyPrice             Decimal  @db.Decimal(10, 2)
  monthlyStripePriceId    String?
  yearlyStripePriceId     String?
  gptModel                String   // e.g. 'gpt-3.5-turbo', 'gpt-4o'
  aiGenerationsPerMonth   Int?     // null = unlimited
  maxSavedProgressions    Int?     // null = unlimited
  maxSavedArrangements    Int?     // null = unlimited
  maxPublicShares         Int?     // null = unlimited
  canExportMidi           Boolean  @default(false)
  canExportPdf            Boolean  @default(false)
  canSharePublicly        Boolean  @default(true)
  canUsePremiumAiModel    Boolean  @default(false)
  versionNumber           Int      // Incremented on each new version
  isDraft                 Boolean  @default(false)
  isActive                Boolean  @default(false)
  publishedAt             DateTime?
  editorEmail             String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([planId, versionNumber])
  @@index([isActive])
  @@index([isDraft])
  @@index([planId, isActive])
  @@index([planId, createdAt])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorEmail  String
  actorRole   UserRole
  action      String
  targetType  String
  targetId    String
  metadata    Json?
  createdAt   DateTime @default(now())

  actorUser User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([actorUserId, createdAt])
}

model PromptVersion {
  id              String   @id @default(cuid())
  promptKey       String
  versionNumber   Int
  contentTemplate String
  notes           String?
  isDraft         Boolean  @default(false)
  isActive        Boolean  @default(false)
  createdByUserId String?
  createdByEmail  String?
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdByUser User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([promptKey, versionNumber])
  @@index([promptKey, isActive])
  @@index([promptKey, isDraft])
  @@index([promptKey, createdAt])
}

model Progression {
  id         String   @id @default(cuid())
  shareId    String   @unique @default(cuid())
  userId     String
  title      String
  chords     Json
  pianoVoicings Json?
  generatorSnapshot Json?
  feel       String?
  scale      String?
  genre      String?
  notes      String?
  tags       String[]
  isPublic   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([shareId])
}

model Arrangement {
  id               String   @id @default(cuid())
  shareId          String   @unique @default(cuid())
  userId           String
  title            String
  timeline         Json
  playbackSnapshot Json
  sourceChords     Json?
  notes            String?
  tags             String[] @default([])
  isPublic         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([shareId])
}
