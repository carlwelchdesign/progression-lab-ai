// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  AUDITOR
  USER
}

enum SubscriptionPlan {
  SESSION
  COMPOSER
  STUDIO
  COMP
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

enum UsageEventType {
  AI_GENERATION
  MIDI_EXPORT
  PDF_EXPORT
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String?
  role         UserRole      @default(USER)
  stripeCustomerId String?   @unique
  planOverride SubscriptionPlan?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  progressions Progression[]
  arrangements Arrangement[]
  subscription Subscription?
  usageEvents  UsageEvent[]
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 SubscriptionPlan
  billingInterval      BillingInterval?
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([plan, status])
}

model UsageEvent {
  id        String         @id @default(cuid())
  userId    String
  eventType UsageEventType
  quantity  Int            @default(1)
  metadata  Json?
  createdAt DateTime       @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, eventType, createdAt])
}

model SubscriptionTierConfig {
  plan                   SubscriptionPlan @id
  gptModel               String
  aiGenerationsPerMonth  Int?
  maxSavedProgressions   Int?
  maxSavedArrangements   Int?
  maxPublicShares        Int?
  canExportMidi          Boolean          @default(false)
  canExportPdf           Boolean          @default(false)
  canSharePublicly       Boolean          @default(true)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
}

model Progression {
  id         String   @id @default(cuid())
  shareId    String   @unique @default(cuid())
  userId     String
  title      String
  chords     Json
  pianoVoicings Json?
  generatorSnapshot Json?
  feel       String?
  scale      String?
  genre      String?
  notes      String?
  tags       String[]
  isPublic   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([shareId])
}

model Arrangement {
  id               String   @id @default(cuid())
  shareId          String   @unique @default(cuid())
  userId           String
  title            String
  timeline         Json
  playbackSnapshot Json
  sourceChords     Json?
  notes            String?
  tags             String[] @default([])
  isPublic         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([shareId])
}
